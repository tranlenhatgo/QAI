# AI Study Coach ‚Äî Environment Variables
# Copy to .env and fill in your values

# Quiz App API (your Spring Boot backend)
COACH_QUIZ_API_URL=http://localhost:8080

# ‚îÄ‚îÄ‚îÄ Primary LLM: LM Studio ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Download and install: https://lmstudio.ai
# Load a model in the LM Studio app, then set the URL below.
# LM Studio exposes an OpenAI-compatible API at /v1/chat/completions.
COACH_EXTERNAL_LLM_PROVIDER=lm_studio
COACH_LM_STUDIO_URL=http://127.0.0.1:1234

# ‚îÄ‚îÄ‚îÄ Alternative: External Cloud APIs ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Option 1: DeepSeek API (cloud ó DeepSeek V4 Flash)
#   Get a key at: https://aistudio.google.com
# COACH_EXTERNAL_LLM_PROVIDER=google
# COACH_EXTERNAL_LLM_API_KEY=
# COACH_EXTERNAL_LLM_MODEL=deepseek-v4-flash

# CORS (your frontend URL)
COACH_CORS_ORIGINS=["http://localhost:3000"]

# Security ‚Äî API key for protected endpoints
# Set this to require X-API-Key header on /chat endpoints
COACH_API_KEY=
